# Database
DATABASE_URL="postgresql://user:password@localhost:5432/store_db?schema=public"

# JWT Secrets (generate with: openssl rand -base64 64)
JWT_ACCESS_SECRET="your-access-secret-min-32-chars"
JWT_REFRESH_SECRET="your-refresh-secret-min-32-chars"

# CORS
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:8080"

# App
NODE_ENV="development"
NEXT_PUBLIC_API_URL="http://localhost:3000/api/v1"

# Admin Panel (change this to a non-guessable path in production)
ADMIN_PATH_PREFIX="mx-panel"

# Admin IP Allowlist (comma-separated, leave empty to disable)
ADMIN_IP_ALLOWLIST=""

# Trusted IP Header (platform-specific: "cf-connecting-ip" for Cloudflare, "x-vercel-forwarded-for" for Vercel)
TRUSTED_IP_HEADER=""
BEHIND_REVERSE_PROXY="false"

# Cron Secret (for authenticated cron job endpoints)
CRON_SECRET="your-cron-secret-here"
