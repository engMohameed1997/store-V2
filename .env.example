# ============================================
# DATABASE
# ============================================
# For Docker: use "db" as host (service name)
# For local dev: use "localhost"
DB_USER="store_user"
DB_PASSWORD="CHANGE_ME_IN_PRODUCTION"
DB_NAME="store_db"
DB_PORT="5432"
DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@localhost:${DB_PORT}/${DB_NAME}?schema=public"

# ============================================
# JWT SECRETS (CRITICAL - Must change in production!)
# Generate with: openssl rand -base64 64
# ============================================
JWT_ACCESS_SECRET="CHANGE_ME_generate_with_openssl_rand_base64_64"
JWT_REFRESH_SECRET="CHANGE_ME_generate_with_openssl_rand_base64_64"

# ============================================
# CORS
# ============================================
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:8080"

# ============================================
# APP CONFIG
# ============================================
NODE_ENV="development"
NEXT_PUBLIC_API_URL="http://localhost:3000/api/v1"

# ============================================
# ADMIN PANEL
# ============================================
# Change this to a non-guessable path in production
ADMIN_PATH_PREFIX="mx-panel"

# Comma-separated IP allowlist (leave empty to disable)
ADMIN_IP_ALLOWLIST=""

# ============================================
# PROXY / IP RESOLUTION
# ============================================
# Platform-specific header: "cf-connecting-ip" (Cloudflare), "x-vercel-forwarded-for" (Vercel)
TRUSTED_IP_HEADER=""
BEHIND_REVERSE_PROXY="false"

# ============================================
# CRON SECRET
# ============================================
# For authenticated cron job endpoints - generate a strong random value
CRON_SECRET="CHANGE_ME_generate_with_openssl_rand_hex_32"

# ============================================
# UPSTASH REDIS (Required for Rate Limiting & Caching)
# ============================================
# Create a free database at https://console.upstash.com
UPSTASH_REDIS_REST_URL="https://YOUR_ENDPOINT.upstash.io"
UPSTASH_REDIS_REST_TOKEN="CHANGE_ME_your_upstash_token"

# ============================================
# TELEGRAM BOT (Optional — for order notifications)
# ============================================
# IMPORTANT: Never store these in the database. Use env vars only.
# Get your token from @BotFather on Telegram. Get the chat ID via @userinfobot.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# ============================================
# FIREBASE (Phone OTP Verification)
# ============================================
# Client-side config (exposed to browser via NEXT_PUBLIC_*)
NEXT_PUBLIC_FIREBASE_API_KEY="AIzaSyCPqQNbzStVmCnwFCBC_cS9v11XOL05i04"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="store-db0ed.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="store-db0ed"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="103335542930"
NEXT_PUBLIC_FIREBASE_APP_ID="1:103335542930:web:6454399df1c60cc6be664b"
# Server-side Admin SDK — base64-encoded service account JSON
# Generate with: cat service-account.json | base64 -w 0
FIREBASE_SERVICE_ACCOUNT_BASE64=""

# ============================================
# DOCKER CONFIG
# ============================================
APP_PORT="3000"
RUN_MIGRATIONS="true"

# ============================================
# AI CHATBOT (Vercel AI SDK — multi-provider)
# ============================================
# Provider: openai | google | anthropic | local
AI_PROVIDER="openai"
# Model name (defaults: gpt-4o-mini | gemini-2.0-flash | claude-3-5-haiku-20241022)
AI_MODEL="gpt-4o-mini"
# Custom OpenAI-compatible base URL (for local models like text-generation-webui)
# local provider defaults to http://127.0.0.1:5000/v1
AI_BASE_URL=""
OPENAI_API_KEY=""
GOOGLE_GENERATIVE_AI_API_KEY=""
ANTHROPIC_API_KEY=""

# ============================================
# MINIO (Object Storage for Uploads)
# ============================================
MINIO_ROOT_USER="store_minio_admin"
MINIO_ROOT_PASSWORD="CHANGE_ME_strong_minio_password"
MINIO_BUCKET="store-uploads"
MINIO_ENDPOINT="http://minio:9000"
MINIO_PUBLIC_URL="/minio"
